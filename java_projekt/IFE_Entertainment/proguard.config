-keep class SEG11.IFE_Entertainment.** { *; }
# Globale Unterdrückung
-ignorewarnings
-dontnote **
-dontwarn **

# Basis-Einstellungen
-dontshrink
-dontoptimize
-keepattributes Exceptions,InnerClasses,Signature,Deprecated,SourceFile,LineNumberTable,*Annotation*,EnclosingMethod

# WICHTIG: Den Launcher und die App-Klasse nicht umbenennen!
-keep public class SEG11.IFE_Entertainment.Launcher {
    public static void main(java.lang.String[]);
}



-keep class SEG11.IFE_Entertainment.App {
    *;
}

-keep class * extends javafx.application.Application {
    *;
}

# JavaFX-Klassen schützen
-keep class javafx.** { *; }
-keep class com.sun.javafx.** { *; }
-keep class * extends javafx.application.Application {
    public *;
}

# Controller-Methoden und Felder für FXML-Injection schützen
-keep class * {
    @javafx.fxml.FXML *;
}

-keepclassmembers class * {
    @javafx.fxml.FXML *;
    public void *(javafx.event.ActionEvent);
}

# Erhalte alle Controller-Klassen und deren FXML-annotierte Felder/Methoden
-keep class * {
    @javafx.fxml.FXML *;
}

# Alles was mit Reflection/FXML zu tun hat
-keepclassmembers class * {
    public <init>();
}

# Verhindere das Umbenennen von Klassen, die von Application erben
-keep public class * extends javafx.application.Application

# Wichtig für Reflection in FXML
-keepclassmembers class * {
    public void *(javafx.event.ActionEvent);
    }

# Warnungen ignorieren
-dontwarn **
# Ignoriere Warnungen zu fehlenden javax-Klassen
-dontwarn javax.script.**
-dontwarn javax.xml.**
-dontwarn javax.xml.stream.**
-dontwarn javax.xml.namespace.**
-dontwarn java.beans.**

# Ignoriere Warnungen zu internen JavaFX/Glass/Prism Klassen
-dontwarn com.sun.**
-dontwarn javafx.**

-dontwarn org.apache.**
-dontnote javafx.**
-dontnote com.sun.javafx.**
-dontnote com.sun.glass.**

-dontwarn sun.misc.Unsafe
-dontwarn javax.xml.stream.**
-dontwarn javax.script.**
-dontwarn javax.xml.parsers.**
-dontwarn org.xml.sax.**
-dontwarn jdk.jfr.**

-dontwarn com.sun.javafx.logging.jfr.**
-dontwarn com.sun.javafx.font.**
-dontwarn com.sun.marlin.**

-dontnote javafx.**
-dontnote com.sun.javafx.**
-dontnote com.sun.marlin.**
-dontnote com.sun.prism.**
-dontnote com.sun.scenario.**
-dontnote jdk.internal.**
-dontwarn sun.**

-dontnote **

-ignorewarnings
