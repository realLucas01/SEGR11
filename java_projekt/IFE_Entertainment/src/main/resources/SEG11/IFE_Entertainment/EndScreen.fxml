<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.GridPane?>


<BorderPane xmlns="http://javafx.com/javafx/21.0.2"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="SEG11.IFE_Entertainment.UIFourConnectController.FourConnectEndScreenController"
            stylesheets="@style.css" styleClass="end-screen-root">

    <top>
        <Label text="%end.title" styleClass="screen-title" BorderPane.alignment="CENTER"/>
    </top>


    <center>
        <VBox alignment="CENTER" spacing="20">

        	<!-- Label wer gewonnen hat: Zeigt an wer der Gewinner der Runde ist -->
            <Label fx:id="resultLabel" styleClass="screen-title"/>                     
       </VBox>
    </center>
    
    
    <bottom>
    	<GridPane alignment="CENTER" hgap="30" vgap="30">
    	
            <Button text="%menu.newRound"
            		prefWidth="150" prefHeight="50"
            		onAction="#restartGame"
                    GridPane.rowIndex="0" GridPane.columnIndex="0"
                    styleClass="button-secondary"/>
                    
            <Label prefWidth="150" prefHeight="50"
                    GridPane.rowIndex="0" GridPane.columnIndex="1"/>
                    
            <Label prefWidth="150" prefHeight="50"
                    GridPane.rowIndex="0" GridPane.columnIndex="2"/>
                    
			<Button text="%menu.back"
            		prefWidth="150" prefHeight="50"
                    onAction="#backToMainMenu"
                    GridPane.rowIndex="0" GridPane.columnIndex="3"
                    styleClass="button-secondary"/>          
                                        
        </GridPane>
    </bottom>
    
    
</BorderPane>

    <center>
        <VBox alignment="CENTER" spacing="20">
        		<!-- Label wer gewonnen hat: Zeigt an wer der Gewinner der Runde ist -->
            <Label fx:id="resultLabel" styleClass="title"/>
            <!-- Spiel Restart -->
            <Button text="%menu.newRound" onAction="#restartGame"/>
            <!-- Back to Main Menü -->
            <Button text="%menu.back" onAction="#backToMainMenu"/>
        </VBox>
    </center>

</BorderPane>