<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>

<BorderPane xmlns="http://javafx.com/javafx/21.0.2"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="SEG11.IFE_Entertainment.UIFourConnectController.FourConnectGameController"
            stylesheets="@style.css">

	<top>
		<Label text="%game.title" styleClass="title" BorderPane.alignment="CENTER"/>
	</top>

	<center>
		<VBox alignment="CENTER" spacing="20">

			<HBox fx:id="turnBox" spacing="10" alignment="CENTER" styleClass="turn-box">
				<Label text="%game.turn" styleClass="turn-title"/>
				<Label fx:id="statusLabel" text="" styleClass="turn-value"/>
			</HBox>

			<GridPane fx:id="gridPane" hgap="5" vgap="5" alignment="CENTER"/>

			<Button text="%menu.restart"
			        onAction="#restartGame"
			        styleClass="main-button"/>
			<Button text="%menu.help"
			        onAction="#openHelp"
			        styleClass="main-button"/>
			<Button text="%menu.back"
			        onAction="#backToMainMenu"
			        styleClass="main-button"/>

		</VBox>
	</center>

</BorderPane>