<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.layout.GridPane?>

<BorderPane xmlns="http://javafx.com/javafx/21.0.2"
            xmlns:fx="http://javafx.com/javafx/1"
            fx:controller="SEG11.IFE_Entertainment.UIGameController.FourConnectGameController"
            stylesheets="@style.css" styleClass="game-root">



			<!-- Titel -->
    <top>
        <Label text="Four Connect" styleClass="title"/>
    </top>


			<!-- Spielfeld mit Back to Main Menü Button -->
    <center>
        <VBox spacing="20" alignment="CENTER" >

            <GridPane fx:id="gridPane" hgap="5" vgap="5"/>

			<HBox spacing="15" alignment="CENTER" styleClass="game-button-bar">
            <Button text="Restart"
            		prefWidth="150"
			        onAction="#restartGame"
			        styleClass="button-secondary"/>

			<Button text="Help"
					prefWidth="150"
			        onAction="#openHelp"
			        styleClass="button-secondary"/>
			        
            <Button text="Mainmenu"
        			prefWidth="150"
        			onAction="#backToMainMenu"
        			styleClass="button-secondary"/>
        	</HBox>

        </VBox>
    </center>


			<!-- Status Label also wer ist drann oder so... Muss aber nicht sein -->
    <bottom>
        <Label fx:id="statusLabel" styleClass="status-label"/>
    </bottom>

</BorderPane>
