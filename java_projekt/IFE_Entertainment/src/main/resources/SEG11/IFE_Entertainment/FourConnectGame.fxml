<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.VBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Button?>
<?import javafx.geometry.Insets?>

<VBox alignment="CENTER" spacing="20.0"
      xmlns="http://javafx.com/javafx/8.0.171"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="SEG11.IFE_Entertainment.UIController.FourConnectGameController">
    <children>
        <Label text="Four Connect" style="-fx-font-size: 24px; -fx-font-weight: bold;" />
        <Label fx:id="statusLabel" text="Player 1's turn" />
        <Button text="Restart" onAction="#restartGame" />
        <Button text="Help" onAction="#switchToHelp" />
        <Button text="Main Menu" onAction="#switchToMainMenu" />
    </children>
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
    </padding>
</VBox>
