<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.layout.GridPane?>

<BorderPane xmlns="http://javafx.com/javafx/21.0.2"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="SEG11.IFE_Entertainment.UIFourConnectController.FourConnectGameController"
            stylesheets="@style.css" styleClass="game-root">

	<top>
		<Label text="%game.title" styleClass="screen-title" BorderPane.alignment="CENTER"/>
	</top>

	<center>
		<HBox alignment="CENTER" spacing="150">
		
			<GridPane fx:id="gridPane" hgap="12" vgap="12" alignment="CENTER" styleClass="game-grid"/>
			
			
		<VBox alignment="CENTER" spacing="50">
			
			<!-- Zeigt den aktuellen "Turn" an also wer gerade am Zug ist (aktuell drann ist) -->
			<VBox fx:id="turnBox" spacing="10" alignment="TOP_LEFT" styleClass="turn-box">
				<Label text="%game.turn" styleClass="turn-title"/>
				<Label fx:id="statusLabel" text="" styleClass="turn-value"/>
			</VBox>
		
			<VBox spacing="24" alignment="BOTTOM_LEFT" styleClass="game-button-bar">
				<!-- Setzt das Grid zurück -->
				<Button text="%menu.restart"
            			prefWidth="150" prefHeight="50"
				        onAction="#restartGame"
				        styleClass="button-secondary"/>
				<!-- Zeigt die Hilfe Seite an -->
				<Button text="%menu.help"
           		 		prefWidth="150" prefHeight="50"
				        onAction="#openHelp"
				        styleClass="button-secondary"/>
				<!-- Kehrt zurück zum Hauptmenü zurück -->
				<Button text="%menu.back"
          		  		prefWidth="150" prefHeight="50"
				        onAction="#backToMainMenu"
				        styleClass="button-secondary"/>
			</VBox>
		</VBox>
		
		</HBox>
	</center>


			<!-- Status Label also wer ist drann oder so... Muss aber nicht sein -->
    <bottom>
        <Label fx:id="statusLabel" styleClass="status-label"/>
    </bottom>

</BorderPane>
