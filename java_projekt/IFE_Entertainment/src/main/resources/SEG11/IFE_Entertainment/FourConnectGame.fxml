<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.layout.GridPane?>

<BorderPane xmlns="http://javafx.com/javafx/21.0.2"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="SEG11.IFE_Entertainment.UIGameController.FourConnectGameController"
            stylesheets="@style.css">

    <top>
        <Label text="Four Connect" styleClass="title"/>
    </top>

    <center>
        <VBox alignment="CENTER" spacing="20">

            <GridPane fx:id="gridPane" hgap="5" vgap="5"/>

            <Button text="Back"
                    onAction="#backToMainMenu"
                    styleClass="main-button"/>

        </VBox>
    </center>

    <bottom>
        <Label text="Player turn / status" styleClass="status-label"/>
    </bottom>

</BorderPane>