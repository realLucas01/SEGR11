<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>

<BorderPane xmlns="http://javafx.com/javafx/21.0.2"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="SEG11.IFE_Entertainment.UIFourConnectController.FourConnectHelpController"
            stylesheets="@style.css">



		<!-- Selbsterklärende Beschreibung des Spiels und wie gespielt wird -->
    <top>
        <Label text="%help.title" styleClass="title"/>
    </top>

    <center>
        <VBox spacing="15" alignment="CENTER">
            <Label text="%help.rules_game" wrapText="true"/>
        </VBox>
    </center>

    <bottom>
        <VBox alignment="CENTER" spacing="50" style="-fx-padding: 15;">
            <Button text="%menu.back" onAction="#backToGameScreen"/>
        </VBox>
    </bottom>

</BorderPane>