<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns="http://javafx.com/javafx/21.0.2"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="SEG11.IFE_Entertainment.UIController.MainMenuController"
            stylesheets="@style.css"
            maxWidth="Infinity"
            maxHeight="Infinity">

    <!-- TOP BAR -->
    <top>
        <HBox alignment="CENTER" spacing="20" style="-fx-padding: 10;">
            <Label text="Gamemenu"
                   style="-fx-font-size: 20px; -fx-font-weight: bold;"
                   HBox.hgrow="ALWAYS"
                   alignment="CENTER"/>
        </HBox>
    </top>

    <!-- GAME GRID -->
    <center>
        <GridPane alignment="CENTER" hgap="30" vgap="30">

            <!-- Reihe 1 -->
            <Button text="4 Gewinnt"
                    prefWidth="150" prefHeight="100"
                    onAction="#startGame"
                    GridPane.rowIndex="0" GridPane.columnIndex="0"/>
            <Button text="Spiel 2"
                    prefWidth="150" prefHeight="100"
                    GridPane.rowIndex="0" GridPane.columnIndex="1"/>
            <Button text="Spiel 3"
                    prefWidth="150" prefHeight="100"
                    GridPane.rowIndex="0" GridPane.columnIndex="2"/>
            <Button text="Spiel 4"
                    prefWidth="150" prefHeight="100"
                    GridPane.rowIndex="0" GridPane.columnIndex="3"/>

            <!-- Reihe 2 -->
            <Button text="Spiel 5"
                    prefWidth="150" prefHeight="100"
                    GridPane.rowIndex="1" GridPane.columnIndex="0"/>
            <Button text="Spiel 6"
                    prefWidth="150" prefHeight="100"
                    GridPane.rowIndex="1" GridPane.columnIndex="1"/>
            <Button text="Spiel 7"
                    prefWidth="150" prefHeight="100"
                    GridPane.rowIndex="1" GridPane.columnIndex="2"/>
            <Button text="Spiel 8"
                    prefWidth="150" prefHeight="100"
                    GridPane.rowIndex="1" GridPane.columnIndex="3"/>

        </GridPane>
    </center>

    <!-- BOTTOM BAR -->
    <bottom>
        <HBox alignment="CENTER" spacing="50" style="-fx-padding: 15;">
            <Button text="%menu.help"
                    prefWidth="120"
                    onAction="#openHelp"/>
            <Button text="%menu.exit"
                    prefWidth="120"
                    onAction="#exit"/>
            <Button text="%menu.settings"
                    prefWidth="120"
                    onAction="#openSettings"/>
        </HBox>
    </bottom>

</BorderPane>