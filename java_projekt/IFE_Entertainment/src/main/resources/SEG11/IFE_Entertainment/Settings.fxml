<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.VBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Button?>
<?import javafx.geometry.Insets?>

<VBox alignment="CENTER" spacing="20.0"
      xmlns="http://javafx.com/javafx/8.0.171"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="SEG11.IFE_Entertainment.UIController.SettingsController">
    <children>
        <Label text="Settings" style="-fx-font-size: 24px; -fx-font-weight: bold;" />
        <Label text="Language" style="-fx-font-size: 16px;" />
        <Button text="English" onAction="#setLanguageEnglish" />
        <Button text="Deutsch" onAction="#setLanguageGerman" />
        <Button text="Back to Main Menu" onAction="#switchToMainMenu" />
    </children>
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
    </padding>
</VBox>
