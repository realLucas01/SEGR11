<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>

<BorderPane xmlns="http://javafx.com/javafx/21.0.2"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="SEG11.IFE_Entertainment.UIController.MainHelpController"
            stylesheets="@style.css">

    <!-- Titel -->
    <top>
        <Label text="Hilfe – Hauptmenü" styleClass="title" alignment="CENTER"/>
    </top>

    <!-- Inhalt -->
    <center>
        <VBox spacing="15" alignment="CENTER">

            <Label text="Bedienung der Anwendung"
                   style="-fx-font-size: 20px; -fx-font-weight: bold;"/>

            <Label wrapText="true"
                   text="Dieses System dient zur Auswahl und Nutzung verschiedener Spiele&#10;
innerhalb des Inflight-Entertainment-Systems.&#10;&#10;
Im Hauptmenü werden alle verfügbaren Spiele als Kacheln angezeigt.&#10;&#10;
• Durch Anklicken einer Spiel-Kachel wird das jeweilige Spiel gestartet.&#10;
• Der Button 'Help' öffnet diese Hilfeseite.&#10;
• Über 'Settings' können Einstellungen angepasst werden.&#10;
• Mit 'Exit' wird die Anwendung beendet.&#10;&#10;
Die Bedienung erfolgt vollständig über Maus oder Touch-Eingaben.&#10;
Alle Funktionen sind über klar beschriftete Schaltflächen erreichbar.&#10;&#10;
Je nach Spiel können zusätzliche Menüs oder Optionen erscheinen,&#10;
z. B. zur Auswahl des Spielmodus."/>
        </VBox>
    </center>

    <!-- Zurück -->
    <bottom>
        <VBox alignment="CENTER" spacing="50" style="-fx-padding: 15;">
            <Button text="Zurück"
                    onAction="#backToMainMenu"/>
        </VBox>
    </bottom>

</BorderPane>