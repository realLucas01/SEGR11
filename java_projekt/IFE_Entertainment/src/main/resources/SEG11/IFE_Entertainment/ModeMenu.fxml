<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>

<BorderPane xmlns="http://javafx.com/javafx/21.0.2"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="SEG11.IFE_Entertainment.UIController.ModeMenuController"
            stylesheets="@style.css" styleClass="mode-menu-root">

    <top>
        <Label text="Select Mode" styleClass="title"/>
    </top>

    <center>
        <VBox alignment="CENTER" spacing="20">

			 <!-- Java handled, in Java dann z.B. startGame("PVP"); -->
            <Button text="Two Player-Mode"
                    prefWidth="200"
                    onAction="#startGame"
                    styleClass="button-primary"/>
                    
            <Button text="VS Easy Bot"
            			prefWidth="200"
			        onAction="#startGameEasyBot"
			        styleClass="button-primary"/>
			
			<Button text="VS Hard Bot"
					prefWidth="200"
			        onAction="#startGameHardBot"
			        styleClass="button-primary"/>

            <Button text="Back"
                    prefWidth="150"
                    onAction="#backToMainMenu"
        			styleClass="button-secondary"/>

        </VBox>
    </center>

</BorderPane>

