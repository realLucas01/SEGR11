<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>

<BorderPane xmlns="http://javafx.com/javafx/21.0.2"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="SEG11.IFE_Entertainment.UIController.MainMenuController">

    <top>
        <Label text="Select Mode" styleClass="title"/>
    </top>

    <center>
        <VBox alignment="CENTER" spacing="20">

            <Button text="Two Players"
                    prefWidth="200"
                    onAction="#startPvP"/>

            <Button text="Vs Computer"
                    prefWidth="200"
                    onAction="#startBot"/>

            <Button text="Back"
                    prefWidth="150"
                    onAction="#backToMainMenu"/>

        </VBox>
    </center>

</BorderPane>