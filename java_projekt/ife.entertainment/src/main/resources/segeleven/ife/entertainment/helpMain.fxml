<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>

<BorderPane xmlns="http://javafx.com/javafx/21.0.2"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="segeleven.ife.entertainment.uicontroller.MainHelpController"
            stylesheets="@style.css">

    <!-- Titel -->
    <top>
        <Label text="Hilfe – Hauptmenü" styleClass="title" alignment="CENTER"/>
    </top>

    <!-- Inhalt -->
    <center>
        <VBox spacing="15" alignment="CENTER">

        <VBox spacing="15" alignment="CENTER">
            <Label text="%help.rules_menu" wrapText="true"/>
        </VBox>
        </VBox>
    </center>

    <!-- Zurück -->
    <bottom>
        <VBox alignment="CENTER" spacing="50" style="-fx-padding: 15;">
            <Button text="Zurück"
                    onAction="#backToMainMenu"/>
        </VBox>
    </bottom>

</BorderPane>
